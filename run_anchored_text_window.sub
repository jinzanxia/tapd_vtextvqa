#!/bin/bash
#SBATCH --job-name=sfa_anchorwin
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=48:00:00
#SBATCH --array=0-3
#SBATCH -o ./logs/anchorwin_%a.%N.%j.out
#SBATCH -e ./logs/anchorwin_%a.%N.%j.err

set -euo pipefail

IMAGE="docker://xiaojino/sfa:v1.2"
SCRIPT_PATH="$PWD/infer_codes/qwen.py"
D2_CONFIG="$PWD/detectron2_coco.yaml"

DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"
VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

mkdir -p ./logs ./results

# Anchored text window experiments
# 0: anchored_fixed_k2
#    Top-2 text clusters -> fixed 0.4 windows, no hybrid skeleton.
# 1: hybrid_k2_center_anchored_fixed_k2
#    Best baseline skeleton + top-2 anchored fixed windows.
# 2: anchored_adaptive_k2
#    Top-2 text clusters -> adaptive windows from {0.4,0.6,0.8}, no hybrid skeleton.
# 3: hybrid_k2_center_anchored_adaptive_k2
#    Best baseline skeleton + top-2 anchored adaptive windows.
EXPERIMENT_NAMES=(
  "anchored_fixed_k2"
  "hybrid_k2_center_anchored_fixed_k2"
  "anchored_adaptive_k2"
  "hybrid_k2_center_anchored_adaptive_k2"
)

COMMON_ARGS="--no-ocr-text --no-focus-bonus --no-object-detect --d2-config '${D2_CONFIG}' --density-top-k 2 --density-nms 0.5"

case ${SLURM_ARRAY_TASK_ID} in
  0)
    EXTRA_ARGS="${COMMON_ARGS} --layout-zoom off --crop-mode density --text-anchor-mode fixed --text-anchor-fixed-scale 0.4"
    ;;
  1)
    EXTRA_ARGS="${COMMON_ARGS} --layout-zoom center --crop-mode hybrid --text-anchor-mode fixed --text-anchor-fixed-scale 0.4"
    ;;
  2)
    EXTRA_ARGS="${COMMON_ARGS} --layout-zoom off --crop-mode density --text-anchor-mode adaptive --text-anchor-scales 0.4,0.6,0.8"
    ;;
  3)
    EXTRA_ARGS="${COMMON_ARGS} --layout-zoom center --crop-mode hybrid --text-anchor-mode adaptive --text-anchor-scales 0.4,0.6,0.8"
    ;;
esac

EXP_NAME="${EXPERIMENT_NAMES[${SLURM_ARRAY_TASK_ID}]}"
OUTPUT_JSON="./results/${EXP_NAME}.json"

echo "=========================================="
echo "Anchored text window experiment: ${EXP_NAME}"
echo "SLURM_ARRAY_TASK_ID: ${SLURM_ARRAY_TASK_ID}"
echo "EXTRA_ARGS: ${EXTRA_ARGS}"
echo "OUTPUT_JSON: ${OUTPUT_JSON}"
echo "=========================================="

if command -v apptainer >/dev/null 2>&1; then
  CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  CTR="singularity"
else
  echo "Neither apptainer nor singularity found."
  exit 1
fi

${CTR} exec --nv "${IMAGE}" bash -lc "
  test -f '${SCRIPT_PATH}' || { echo 'Missing script: ${SCRIPT_PATH}'; exit 1; }
  test -f '${D2_CONFIG}'   || { echo 'Missing detectron2 config: ${D2_CONFIG}'; exit 1; }
  test -f '${GT_JSON}'     || { echo 'Missing gt json: ${GT_JSON}'; exit 1; }
  test -d '${VIDEO_DIR}'   || { echo 'Missing video dir: ${VIDEO_DIR}'; exit 1; }
  test -f '${VTS_MODEL}'   || { echo 'Missing model: ${VTS_MODEL}'; exit 1; }
  python -c 'import detectron2, adet' || { echo 'Missing detectron2/adet in image'; exit 1; }
"

${CTR} exec --nv \
  --env TOKENIZERS_PARALLELISM=false \
  "${IMAGE}" \
  bash -lc "
    python -c 'import flash_attn' >/dev/null 2>&1 || \
      python -m pip install --no-cache-dir --no-build-isolation flash-attn==2.7.2.post1
    python '${SCRIPT_PATH}' \
      --gt-json '${GT_JSON}' \
      --model-name Qwen/Qwen2.5-VL-7B-Instruct \
      --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
      --vts-model '${VTS_MODEL}' \
      --video-dir '${VIDEO_DIR}' \
      --output '${OUTPUT_JSON}' \
      ${EXTRA_ARGS}
  "

echo "Experiment ${EXP_NAME} finished. Results: ${OUTPUT_JSON}"

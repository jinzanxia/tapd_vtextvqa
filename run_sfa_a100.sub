#!/bin/bash
#SBATCH --job-name=sfa_m4_eval
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=48:00:00
#SBATCH -o ./logs/slurm.%N.%j.out
#SBATCH -e ./logs/slurm.%N.%j.err

set -euo pipefail

# ===== User-configurable paths =====
IMAGE="docker://xiaojino/sfa:v1.0"
CODE_DIR="/workspace/SFA"
HOST_CODE_DIR="${SLURM_SUBMIT_DIR}"
DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"
OUTPUT_JSON="${HOST_CODE_DIR}/results/m4_vitevqa_val_pred.json"
HF_CACHE="${HOST_CODE_DIR}/.hf_cache"

# GoMatching checkpoint in dataset dir:
VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

mkdir -p "${HOST_CODE_DIR}/logs" "${HOST_CODE_DIR}/results" "${HF_CACHE}"

if [[ ! -f "${VTS_MODEL}" ]]; then
  echo "Missing VTS model: ${VTS_MODEL}"
  exit 1
fi

# Prefer apptainer, fallback to singularity.
if command -v apptainer >/dev/null 2>&1; then
  CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  CTR="singularity"
else
  echo "Neither apptainer nor singularity found on this cluster."
  exit 1
fi

SCRIPT_PATH="${CODE_DIR}/infer_codes/qwen.py"

${CTR} exec --nv \
  --pwd "${CODE_DIR}" \
  -B "${HOST_CODE_DIR}:${CODE_DIR}" \
  -B "${DATA_DIR}:/data" \
  -B "${HF_CACHE}:/hf_cache" \
  --env HF_HOME=/hf_cache \
  --env TRANSFORMERS_CACHE=/hf_cache \
  --env TOKENIZERS_PARALLELISM=false \
  "${IMAGE}" \
  bash -lc '
    set -euo pipefail
    export PYTHONUSERBASE=/workspace/SFA/.pyuser
    export PATH=/workspace/SFA/.pyuser/bin:$PATH
    export FORCE_CUDA=1

    if ! python -c "import detectron2; import adet" >/dev/null 2>&1; then
      echo "[bootstrap] Installing detectron2/adet into user site ..."
      python -m pip install --user --no-cache-dir -r ./GoMatching/third_party/detectron2/requirements.txt
      python -m pip install --user --no-cache-dir --no-build-isolation -e ./GoMatching/third_party/detectron2
      python -m pip install --user --no-cache-dir --no-build-isolation --no-deps -e ./GoMatching/third_party
    fi

    python "'"${SCRIPT_PATH}"'" \
      --gt-json /data/Annotations/ViteVQA_0.0.2_t1s1val.json \
      --model-name Qwen/Qwen2.5-VL-7B-Instruct \
      --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
      --vts-model /data/GoMatching_pp_vitaeb_bovtext.pth \
      --video-dir /data/video \
      --output "'"${OUTPUT_JSON}"'"
  '

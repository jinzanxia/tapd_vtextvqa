#!/bin/bash
#SBATCH --job-name=sfa_kf
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=48:00:00
#SBATCH --array=0-6
#SBATCH -o ./logs/kf_%a.%N.%j.out
#SBATCH -e ./logs/kf_%a.%N.%j.err

set -euo pipefail

IMAGE="docker://xiaojino/sfa:v1.2"
SCRIPT_PATH="$PWD/infer_codes/qwen.py"

DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"
VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

mkdir -p ./logs ./results

# ===== Keyframe sampling ablation =====
#   0: A — Baseline (no keyframe sampling)
#   1: B — Center sampling, N=8, k=1
#   2: C — Sharpness sampling, N=8, k=1
#   3: D — Sharpness sampling, N=12, k=1
#   4: E — Sharpness sampling, N=8, k=2
#   5: F — Sharpness N=8 k=1 + layout-zoom center
#   6: G — Sharpness N=8 k=1 + layout-zoom full

EXPERIMENT_NAMES=("baseline" "kf_center_8_1" "kf_sharp_8_1" "kf_sharp_12_1" "kf_sharp_8_2" "kf_sharp_8_1_lz_center" "kf_sharp_8_1_lz_full")

case ${SLURM_ARRAY_TASK_ID} in
  0)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom off --kf-sample off"
    ;;
  1)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom off --kf-sample center --kf-segments 8 --kf-neighbors 1"
    ;;
  2)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom off --kf-sample sharpness --kf-segments 8 --kf-neighbors 1"
    ;;
  3)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom off --kf-sample sharpness --kf-segments 12 --kf-neighbors 1"
    ;;
  4)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom off --kf-sample sharpness --kf-segments 8 --kf-neighbors 2"
    ;;
  5)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom center --kf-sample sharpness --kf-segments 8 --kf-neighbors 1"
    ;;
  6)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom full --kf-sample sharpness --kf-segments 8 --kf-neighbors 1"
    ;;
esac

EXP_NAME="${EXPERIMENT_NAMES[${SLURM_ARRAY_TASK_ID}]}"
OUTPUT_JSON="./results/kf_${EXP_NAME}.json"

echo "=========================================="
echo "Keyframe sample experiment: ${EXP_NAME}"
echo "SLURM_ARRAY_TASK_ID: ${SLURM_ARRAY_TASK_ID}"
echo "EXTRA_ARGS: ${EXTRA_ARGS}"
echo "OUTPUT_JSON: ${OUTPUT_JSON}"
echo "=========================================="

if command -v apptainer >/dev/null 2>&1; then
  CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  CTR="singularity"
else
  echo "Neither apptainer nor singularity found."
  exit 1
fi

${CTR} exec --nv \
  --env TOKENIZERS_PARALLELISM=false \
  "${IMAGE}" \
  bash -lc "
    python -c 'import flash_attn' >/dev/null 2>&1 || \
      python -m pip install --no-cache-dir --no-build-isolation flash-attn==2.7.2.post1
    python '${SCRIPT_PATH}' \
      --gt-json '${GT_JSON}' \
      --model-name Qwen/Qwen2.5-VL-7B-Instruct \
      --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
      --vts-model '${VTS_MODEL}' \
      --video-dir '${VIDEO_DIR}' \
      --output '${OUTPUT_JSON}' \
      ${EXTRA_ARGS}
  "

echo "Experiment ${EXP_NAME} finished. Results: ${OUTPUT_JSON}"

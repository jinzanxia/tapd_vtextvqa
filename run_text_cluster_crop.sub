#!/bin/bash
#SBATCH --job-name=sfa_txtcluster
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=48:00:00
#SBATCH --array=0-9
#SBATCH -o ./logs/txtcluster_%a.%N.%j.out
#SBATCH -e ./logs/txtcluster_%a.%N.%j.err

set -euo pipefail

IMAGE="docker://xiaojino/sfa:v1.2"
SCRIPT_PATH="$PWD/infer_codes/qwen.py"
D2_CONFIG="$PWD/detectron2_coco.yaml"

DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"
VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

# COCO-mappable subset for filtered-object experiment:
# stop sign(11), car(2), bus(5), truck(7), bottle(39), tv(62), book(73)
D2_OBJ_CLASSES="11,2,5,7,39,62,73"

mkdir -p ./logs ./results

# Text-cluster proposal experiments
# k=2
# 0: textcluster_k2
#    Only top-2 text clusters (cluster union boxes), no object expansion.
# 1: textcluster_k2_object
#    Top-2 text clusters expanded to related objects (all classes).
# 2: hybrid_k2_center_textcluster
#    Best baseline (4 corners + frame center) + top-2 text clusters.
# 3: hybrid_k2_center_textcluster_object
#    Best baseline + top-2 text clusters expanded to related objects (all classes).
# 4: hybrid_k2_center_textcluster_object_clsfilter
#    Best baseline + top-2 text clusters expanded to related filtered objects.
# k=4
# 5: textcluster_k4
#    Only top-4 text clusters (cluster union boxes), no object expansion.
# 6: textcluster_k4_object
#    Top-4 text clusters expanded to related objects (all classes).
# 7: hybrid_k2_center_textcluster_k4
#    Best baseline (4 corners + frame center) + top-4 text clusters.
# 8: hybrid_k2_center_textcluster_k4_object
#    Best baseline + top-4 text clusters expanded to related objects (all classes).
# 9: hybrid_k2_center_textcluster_k4_object_clsfilter
#    Best baseline + top-4 text clusters expanded to related filtered objects.
EXPERIMENT_NAMES=(
  "textcluster_k2"
  "textcluster_k2_object"
  "hybrid_k2_center_textcluster"
  "hybrid_k2_center_textcluster_object"
  "hybrid_k2_center_textcluster_object_clsfilter"
  "textcluster_k4"
  "textcluster_k4_object"
  "hybrid_k2_center_textcluster_k4"
  "hybrid_k2_center_textcluster_k4_object"
  "hybrid_k2_center_textcluster_k4_object_clsfilter"
)

COMMON_ARGS="--no-ocr-text --no-focus-bonus --d2-config '${D2_CONFIG}' --density-nms 0.5"

case ${SLURM_ARRAY_TASK_ID} in
  0)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 2 --layout-zoom off --crop-mode density --no-object-detect"
    ;;
  1)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 2 --layout-zoom off --crop-mode density"
    ;;
  2)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 2 --layout-zoom center --crop-mode hybrid --no-object-detect"
    ;;
  3)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 2 --layout-zoom center --crop-mode hybrid"
    ;;
  4)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 2 --layout-zoom center --crop-mode hybrid --d2-obj-classes ${D2_OBJ_CLASSES}"
    ;;
  5)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 4 --layout-zoom off --crop-mode density --no-object-detect"
    ;;
  6)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 4 --layout-zoom off --crop-mode density"
    ;;
  7)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 4 --layout-zoom center --crop-mode hybrid --no-object-detect"
    ;;
  8)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 4 --layout-zoom center --crop-mode hybrid"
    ;;
  9)
    EXTRA_ARGS="${COMMON_ARGS} --density-top-k 4 --layout-zoom center --crop-mode hybrid --d2-obj-classes ${D2_OBJ_CLASSES}"
    ;;
esac

EXP_NAME="${EXPERIMENT_NAMES[${SLURM_ARRAY_TASK_ID}]}"
OUTPUT_JSON="./results/${EXP_NAME}.json"

echo "=========================================="
echo "Text-cluster crop experiment: ${EXP_NAME}"
echo "SLURM_ARRAY_TASK_ID: ${SLURM_ARRAY_TASK_ID}"
echo "EXTRA_ARGS: ${EXTRA_ARGS}"
echo "OUTPUT_JSON: ${OUTPUT_JSON}"
echo "=========================================="

if command -v apptainer >/dev/null 2>&1; then
  CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  CTR="singularity"
else
  echo "Neither apptainer nor singularity found."
  exit 1
fi

${CTR} exec --nv "${IMAGE}" bash -lc "
  test -f '${SCRIPT_PATH}' || { echo 'Missing script: ${SCRIPT_PATH}'; exit 1; }
  test -f '${D2_CONFIG}'   || { echo 'Missing detectron2 config: ${D2_CONFIG}'; exit 1; }
  test -f '${GT_JSON}'     || { echo 'Missing gt json: ${GT_JSON}'; exit 1; }
  test -d '${VIDEO_DIR}'   || { echo 'Missing video dir: ${VIDEO_DIR}'; exit 1; }
  test -f '${VTS_MODEL}'   || { echo 'Missing model: ${VTS_MODEL}'; exit 1; }
  python -c 'import detectron2, adet' || { echo 'Missing detectron2/adet in image'; exit 1; }
"

${CTR} exec --nv \
  --env TOKENIZERS_PARALLELISM=false \
  "${IMAGE}" \
  bash -lc "
    python -c 'import flash_attn' >/dev/null 2>&1 || \
      python -m pip install --no-cache-dir --no-build-isolation flash-attn==2.7.2.post1
    python '${SCRIPT_PATH}' \
      --gt-json '${GT_JSON}' \
      --model-name Qwen/Qwen2.5-VL-7B-Instruct \
      --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
      --vts-model '${VTS_MODEL}' \
      --video-dir '${VIDEO_DIR}' \
      --output '${OUTPUT_JSON}' \
      ${EXTRA_ARGS}
  "

echo "Experiment ${EXP_NAME} finished. Results: ${OUTPUT_JSON}"

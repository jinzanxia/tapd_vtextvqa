#!/bin/bash
#SBATCH --job-name=sfa_pc
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=48:00:00
#SBATCH --array=0-5
#SBATCH -o ./logs/pc_%a.%N.%j.out
#SBATCH -e ./logs/pc_%a.%N.%j.err

set -euo pipefail

# ===== User-configurable paths =====
IMAGE="docker://xiaojino/sfa:v1.2"
SCRIPT_PATH="$PWD/infer_codes/qwen.py"

DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"
VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

mkdir -p ./logs ./results

# ===== Post-correction ablation experiments =====
#   0: A — Baseline (no OCR, no post-correct)
#   1: B — Post-correct only (max_edit=2, top_k=20, min_freq=1)
#   2: C — Post-correct strict (max_edit=1, top_k=20, min_freq=2)
#   3: D — Post-correct loose (max_edit=3, top_k=30, min_freq=1)
#   4: E — Post-correct + Focus bonus
#   5: F — Conditional OCR inject + Post-correct (hybrid)

EXPERIMENT_NAMES=("baseline" "pc_edit2_freq1" "pc_edit1_freq2" "pc_edit3_freq1" "pc_edit2_focus" "cond_ocr_plus_pc")

case ${SLURM_ARRAY_TASK_ID} in
  0)
    # A: Baseline — original SFA
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus"
    ;;
  1)
    # B: Post-correct, edit<=2, freq>=1 (default)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --ocr-post-correct --ocr-pc-max-edit 2 --ocr-pc-top-k 20 --ocr-pc-min-freq 1"
    ;;
  2)
    # C: Post-correct strict — edit<=1, freq>=2 (high confidence only)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --ocr-post-correct --ocr-pc-max-edit 1 --ocr-pc-top-k 20 --ocr-pc-min-freq 2"
    ;;
  3)
    # D: Post-correct loose — edit<=3, freq>=1 (more aggressive)
    EXTRA_ARGS="--no-ocr-text --no-focus-bonus --ocr-post-correct --ocr-pc-max-edit 3 --ocr-pc-top-k 30 --ocr-pc-min-freq 1"
    ;;
  4)
    # E: Post-correct + Focus bonus
    EXTRA_ARGS="--no-ocr-text --use-focus-bonus --ocr-post-correct --ocr-pc-max-edit 2 --ocr-pc-top-k 20 --ocr-pc-min-freq 1"
    ;;
  5)
    # F: Conditional OCR inject + Post-correct (hybrid: inject for text Qs, also post-correct all)
    EXTRA_ARGS="--use-ocr-text --conditional-ocr --ocr-top-k 5 --ocr-min-freq 2 --no-focus-bonus --ocr-post-correct --ocr-pc-max-edit 2 --ocr-pc-top-k 20 --ocr-pc-min-freq 1"
    ;;
esac

EXP_NAME="${EXPERIMENT_NAMES[${SLURM_ARRAY_TASK_ID}]}"
OUTPUT_JSON="./results/pc_${EXP_NAME}.json"

echo "=========================================="
echo "Post-correct experiment: ${EXP_NAME}"
echo "SLURM_ARRAY_TASK_ID: ${SLURM_ARRAY_TASK_ID}"
echo "EXTRA_ARGS: ${EXTRA_ARGS}"
echo "OUTPUT_JSON: ${OUTPUT_JSON}"
echo "=========================================="

# Detect container runtime
if command -v apptainer >/dev/null 2>&1; then
  CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  CTR="singularity"
else
  echo "Neither apptainer nor singularity found."
  exit 1
fi

# Preflight checks
${CTR} exec --nv "${IMAGE}" bash -lc "
  test -f '${SCRIPT_PATH}' || { echo 'Missing script: ${SCRIPT_PATH}'; exit 1; }
  test -f '${GT_JSON}'     || { echo 'Missing gt json: ${GT_JSON}'; exit 1; }
  test -d '${VIDEO_DIR}'   || { echo 'Missing video dir: ${VIDEO_DIR}'; exit 1; }
  test -f '${VTS_MODEL}'   || { echo 'Missing model: ${VTS_MODEL}'; exit 1; }
  python -c 'import detectron2, adet' || { echo 'Missing detectron2/adet in image'; exit 1; }
"

# Run experiment
${CTR} exec --nv \
  --env TOKENIZERS_PARALLELISM=false \
  "${IMAGE}" \
  bash -lc "
    python -c 'import flash_attn' >/dev/null 2>&1 || \
      python -m pip install --no-cache-dir --no-build-isolation flash-attn==2.7.2.post1
    python -c 'import editdistance' >/dev/null 2>&1 || \
      python -m pip install --no-cache-dir editdistance
    python '${SCRIPT_PATH}' \
      --gt-json '${GT_JSON}' \
      --model-name Qwen/Qwen2.5-VL-7B-Instruct \
      --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
      --vts-model '${VTS_MODEL}' \
      --video-dir '${VIDEO_DIR}' \
      --output '${OUTPUT_JSON}' \
      ${EXTRA_ARGS}
  "

echo "Experiment ${EXP_NAME} finished. Results: ${OUTPUT_JSON}"

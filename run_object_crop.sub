#!/bin/bash
#SBATCH --job-name=sfa_object
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=48:00:00
#SBATCH --array=0-3
#SBATCH -o ./logs/object_%a.%N.%j.out
#SBATCH -e ./logs/object_%a.%N.%j.err

set -euo pipefail

# ===== User-configurable paths =====
IMAGE="docker://xiaojino/sfa:v1.2"
SCRIPT_PATH="$PWD/infer_codes/qwen.py"
D2_CONFIG="$PWD/detectron2_coco.yaml"

DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"
VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

# Optional: set COCO class ids if you want category filtering, e.g. "0,1,2,3,5,7"
D2_OBJ_CLASSES=""

mkdir -p ./logs ./results

# ===== Object-aware proposal ablation experiments =====
#   0: A — Density text-only proposals (no object detection)
#   1: B — Density text+object union proposals (all classes)
#   2: C — Hybrid text-only proposals (no object detection)
#   3: D — Hybrid text+object union proposals (all classes)

EXPERIMENT_NAMES=(
  "density_text_only"
  "density_text_object"
  "hybrid_text_only"
  "hybrid_text_object"
)

COMMON_ARGS="--no-ocr-text --no-focus-bonus --layout-zoom center --d2-config '${D2_CONFIG}'"

case ${SLURM_ARRAY_TASK_ID} in
  0)
    EXTRA_ARGS="${COMMON_ARGS} --crop-mode density --density-top-k 4 --density-nms 0.5 --no-object-detect"
    ;;
  1)
    EXTRA_ARGS="${COMMON_ARGS} --crop-mode density --density-top-k 4 --density-nms 0.5"
    ;;
  2)
    EXTRA_ARGS="${COMMON_ARGS} --crop-mode hybrid --density-top-k 4 --density-nms 0.5 --no-object-detect"
    ;;
  3)
    EXTRA_ARGS="${COMMON_ARGS} --crop-mode hybrid --density-top-k 4 --density-nms 0.5"
    ;;
esac

if [[ -n "${D2_OBJ_CLASSES}" ]]; then
  EXTRA_ARGS="${EXTRA_ARGS} --d2-obj-classes ${D2_OBJ_CLASSES}"
  FILTER_SUFFIX="_clsfilter"
else
  FILTER_SUFFIX=""
fi

EXP_NAME="${EXPERIMENT_NAMES[${SLURM_ARRAY_TASK_ID}]}${FILTER_SUFFIX}"
OUTPUT_JSON="./results/object_${EXP_NAME}.json"

echo "=========================================="
echo "Object-aware proposal experiment: ${EXP_NAME}"
echo "SLURM_ARRAY_TASK_ID: ${SLURM_ARRAY_TASK_ID}"
echo "D2_OBJ_CLASSES: ${D2_OBJ_CLASSES:-<all classes>}"
echo "EXTRA_ARGS: ${EXTRA_ARGS}"
echo "OUTPUT_JSON: ${OUTPUT_JSON}"
echo "=========================================="

if command -v apptainer >/dev/null 2>&1; then
  CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  CTR="singularity"
else
  echo "Neither apptainer nor singularity found."
  exit 1
fi

${CTR} exec --nv "${IMAGE}" bash -lc "
  test -f '${SCRIPT_PATH}' || { echo 'Missing script: ${SCRIPT_PATH}'; exit 1; }
  test -f '${D2_CONFIG}'   || { echo 'Missing detectron2 config: ${D2_CONFIG}'; exit 1; }
  test -f '${GT_JSON}'     || { echo 'Missing gt json: ${GT_JSON}'; exit 1; }
  test -d '${VIDEO_DIR}'   || { echo 'Missing video dir: ${VIDEO_DIR}'; exit 1; }
  test -f '${VTS_MODEL}'   || { echo 'Missing model: ${VTS_MODEL}'; exit 1; }
  python -c 'import detectron2, adet' || { echo 'Missing detectron2/adet in image'; exit 1; }
"

${CTR} exec --nv \
  --env TOKENIZERS_PARALLELISM=false \
  "${IMAGE}" \
  bash -lc "
    python -c 'import flash_attn' >/dev/null 2>&1 || \
      python -m pip install --no-cache-dir --no-build-isolation flash-attn==2.7.2.post1
    python '${SCRIPT_PATH}' \
      --gt-json '${GT_JSON}' \
      --model-name Qwen/Qwen2.5-VL-7B-Instruct \
      --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
      --vts-model '${VTS_MODEL}' \
      --video-dir '${VIDEO_DIR}' \
      --output '${OUTPUT_JSON}' \
      ${EXTRA_ARGS}
  "

echo "Experiment ${EXP_NAME} finished. Results: ${OUTPUT_JSON}"

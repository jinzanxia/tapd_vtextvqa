#!/bin/bash
#SBATCH --job-name=qwen_finetune
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=80G
#SBATCH --time=72:00:00
#SBATCH -o ./logs/qwen_finetune.%N.%j.out
#SBATCH -e ./logs/qwen_finetune.%N.%j.err

set -euo pipefail

IMAGE="docker://xiaojino/sfa:v2.0"

SCRIPT_PATH="$PWD/infer_codes/qwen_finetune.py"

DATA_DIR="/mnt/fast/nobackup/scratch4weeks/nc324se/data/M4-ViteVQA"
GT_JSON="${DATA_DIR}/Annotations/ViteVQA_0.0.2_t1s1val.json"
VIDEO_DIR="${DATA_DIR}/video"

VTS_MODEL="${DATA_DIR}/GoMatching_pp_vitaeb_bovtext.pth"

OUTPUT_DIR="./checkpoints/qwen_finetune"

mkdir -p ./logs "${OUTPUT_DIR}"

if command -v apptainer >/dev/null 2>&1; then
    CTR="apptainer"
elif command -v singularity >/dev/null 2>&1; then
    CTR="singularity"
else
    echo "Neither apptainer nor singularity found."
    exit 1
fi

# =========================================================
# sanity check
# =========================================================
${CTR} exec --nv \
    --bind "${PWD}:${PWD}" \
    "${IMAGE}" \
    bash -lc "

echo '===== PYTHON ====='
which python || true

echo '===== CONDA PYTHON ====='
ls /opt/conda/envs/qwen/bin/python || true

echo '===== CHECK PROJECT ====='
pwd
ls
ls ${PWD} || true
ls ${PWD}/third_party || true
ls ${PWD}/third_party/AdelaiDet || true

test -f '${SCRIPT_PATH}' || {
    echo 'Missing script: ${SCRIPT_PATH}'
    exit 1
}

test -f '${GT_JSON}' || {
    echo 'Missing gt json: ${GT_JSON}'
    exit 1
}

test -d '${VIDEO_DIR}' || {
    echo 'Missing video dir: ${VIDEO_DIR}'
    exit 1
}

test -f '${VTS_MODEL}' || {
    echo 'Missing VTS model: ${VTS_MODEL}'
    exit 1
}

/opt/conda/envs/qwen/bin/python - <<'PYCODE'
import torch
import transformers
import datasets

print('TORCH:', torch.__version__)
print('CUDA:', torch.cuda.is_available())
print('BASE DEPS OK')
PYCODE

"

# =========================================================
# training
# =========================================================
${CTR} exec --nv \
    --bind "${PWD}:${PWD}" \
    --pwd "${PWD}" \
    --env TOKENIZERS_PARALLELISM=false \
    "${IMAGE}" \
    bash -lc "

export PYTHONPATH=${PWD}/third_party/AdelaiDet:\${PYTHONPATH:-}

echo '===== PYTHONPATH ====='
echo \$PYTHONPATH

echo '===== CHECK PROJECT ====='
pwd
ls
ls third_party || true
ls third_party/AdelaiDet || true

echo '===== INSTALL MISSING DEPS ====='

/opt/conda/envs/qwen/bin/pip install \
    shapely \
    pycocotools \
    yacs \
    fvcore \
    iopath

echo '===== CHECK PYTHON ENV ====='

/opt/conda/envs/qwen/bin/python - <<'PYCODE'
import torch
import shapely
import detectron2
import adet

print('TORCH:', torch.__version__)
print('CUDA:', torch.cuda.is_available())
print('SHAPELY OK')
print('DETECTRON2 OK')
print('ADET OK')
PYCODE

echo '===== START TRAINING ====='

/opt/conda/envs/qwen/bin/python ${SCRIPT_PATH} \
    --gt-json ${GT_JSON} \
    --video-dir ${VIDEO_DIR} \
    --model-name Qwen/Qwen2.5-VL-7B-Instruct \
    --vts-config ./GoMatching/configs/GoMatching_PP_BOVText_vit.yaml \
    --vts-model ${VTS_MODEL} \
    --output-dir ${OUTPUT_DIR} \
    --num-train-epochs 1 \
    --train-batch-size 1 \
    --learning-rate 1e-5 \
    --warmup-steps 0 \
    --max-target-length 64 \
    --max-train-samples 50 \
    --no-ocr-text \
    --no-focus-bonus \
    --layout-zoom center \
    --crop-mode hybrid \
    --density-top-k 2 \
    --density-nms 0.5 \
    --no-object-detect

"

echo "Fine-tuning finished. Output dir: ${OUTPUT_DIR}"